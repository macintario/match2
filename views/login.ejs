<%- include('partials/head') %>

<main class="auth-wrap">
  <section class="card auth-card">
    <div class="auth-brand">
      <img src="<%= basePath %>/logo.png" alt="Logo Match-2" class="auth-brand-logo" />
      <span class="auth-brand-name">MATCH-2</span>
    </div>
    <h1>Ingreso a la plataforma</h1>
    <p>Accede con tu nombre de usuario y contraseña.</p>

    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
    <% } %>

    <form action="<%= basePath %>/login" method="POST" class="form-grid">
      <label>
        Usuario
        <input type="text" name="username" required />
      </label>

      <label>
        Contraseña
        <input type="password" name="password" required />
      </label>

      <button type="submit" class="btn btn-primary">Entrar</button>
    </form>
  </section>
</main>

<%- include('partials/foot') %>
