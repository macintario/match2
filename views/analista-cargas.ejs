<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="main-content">
  <section class="card">
    <div class="row-between">
      <h1>Carga de archivos</h1>
      <a href="/analista" class="btn btn-ghost">Volver al panel</a>
    </div>
    <p>Sube los archivos fuente para actualizar la información del analista.</p>

    <form action="/analista/upload-xml" method="POST" enctype="multipart/form-data" class="form-grid">
      <label>
        Cargar Plantilla (PxP) de docentes y plazas
        <input type="file" name="xmlFile" accept=".xml,.xls,text/xml,application/xml,application/vnd.ms-excel" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary">Procesar Plantilla (PxP)</button>
      </div>
    </form>

    <form action="/analista/upload-historico-xml" method="POST" enctype="multipart/form-data" class="form-grid">
      <label>
        Cargar HISTORICO de asignaturas previas
        <input type="file" name="xmlFile" accept=".xml,.xls,text/xml,application/xml,application/vnd.ms-excel" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary">Procesar HISTORICO</button>
      </div>
    </form>

    <form action="/analista/upload-ruaa-xml" method="POST" enctype="multipart/form-data" class="form-grid">
      <label>
        Cargar RUAA de horarios docentes
        <input type="file" name="xmlFile" accept=".xml,.xls,text/xml,application/xml,application/vnd.ms-excel" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary">Procesar RUAA</button>
      </div>
    </form>

    <form action="/analista/upload-mxg" method="POST" enctype="multipart/form-data" class="form-grid">
      <label>
        Cargar MXG de horarios y horas solicitadas
        <strong>La columna con horas solicitadas debe llamarse "HRSNECESARIAS".</strong>
        <input type="file" name="xmlFile" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary">Procesar MXG</button>
      </div>
    </form>
  </section>
</main>

<%- include('partials/foot') %>
