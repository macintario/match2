<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="main-content">
  <section class="card">
    <div class="row-between">
      <h1>Carga de archivos</h1>
      <a href="<%= basePath %>/analista" class="btn btn-ghost">Volver al panel</a>
    </div>
    <p>Sube los archivos fuente para actualizar la información del analista.</p>

    <form action="<%= basePath %>/analista/upload-xml" method="POST" enctype="multipart/form-data" class="form-grid js-upload-form">
      <label>
        Cargar Plantilla (PxP) de docentes y plazas
        <input type="file" name="xmlFile" accept=".xml,.xls,.xlsx,text/xml,application/xml,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary js-upload-submit">
          <span class="btn-label">Procesar Plantilla (PxP)</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </form>

    <form action="<%= basePath %>/analista/upload-historico-xml" method="POST" enctype="multipart/form-data" class="form-grid js-upload-form">
      <label>
        Cargar HISTORICO de asignaturas previas
        <input type="file" name="xmlFile" accept=".xml,.xls,.xlsx,text/xml,application/xml,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary js-upload-submit">
          <span class="btn-label">Procesar HISTORICO</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </form>

    <form action="<%= basePath %>/analista/upload-ruaa-xml" method="POST" enctype="multipart/form-data" class="form-grid js-upload-form">
      <label>
        Cargar RUAA de horarios docentes
        <input type="file" name="xmlFile" accept=".xml,.xls,.xlsx,text/xml,application/xml,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary js-upload-submit">
          <span class="btn-label">Procesar RUAA</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </form>

    <form action="<%= basePath %>/analista/upload-mxg" method="POST" enctype="multipart/form-data" class="form-grid js-upload-form">
      <label>
        Cargar MXG de horarios y horas solicitadas
        <strong>La columna con horas solicitadas puede llamarse "HRSNECESARIAS" o "HRS SOLICITADAS".</strong>
        <input type="file" name="xmlFile" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required />
      </label>
      <div class="row-actions">
        <button type="submit" class="btn btn-primary js-upload-submit">
          <span class="btn-label">Procesar MXG</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </form>

    <h3>Registro de cargas</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Tipo</th>
            <th>Archivo</th>
            <th>Fecha y hora</th>
            <th>Usuario</th>
            <th>Escuelas</th>
            <th>Docentes</th>
            <th>Plazas</th>
            <th>Asignaturas</th>
            <th>Horarios</th>
            <th>Actividades</th>
            <th>Solicitudes Hrs Adic.</th>
          </tr>
        </thead>
        <tbody>
          <% if (!recentUploads || recentUploads.length === 0) { %>
            <tr>
              <td colspan="12">Aun no hay cargas registradas.</td>
            </tr>
          <% } %>
          <% (recentUploads || []).forEach((upload) => { %>
            <tr>
              <td><%= upload.id %></td>
              <td><%= upload.uploadType || 'PXP' %></td>
              <td><%= upload.originalFileName %></td>
              <td><%= new Date(upload.uploadedAt).toLocaleString('es-MX') %></td>
              <td><%= upload.User ? upload.User.name : '-' %></td>
              <td><%= upload.totalEscuelas %></td>
              <td><%= upload.totalDocentes %></td>
              <td><%= upload.totalPlazas %></td>
              <td><%= upload.totalAsignaturas || 0 %></td>
              <td><%= upload.totalHorarios || 0 %></td>
              <td><%= upload.totalActividades || 0 %></td>
              <td><%= upload.totalSolicitudesAdicionales || 0 %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if (uploadsPagination && uploadsPagination.totalItems > 0) { %>
      <div class="row-between pager">
        <span class="pager-meta">
          Mostrando <%= uploadsPagination.startItem %>-<%= uploadsPagination.endItem %> de <%= uploadsPagination.totalItems %> cargas
          (pagina <%= uploadsPagination.currentPage %> de <%= uploadsPagination.totalPages %>)
        </span>
        <div class="pager-actions">
          <% if (uploadsPagination.hasPrev) { %>
            <a href="<%= uploadsPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
          <% } %>
          <% if (uploadsPagination.hasNext) { %>
            <a href="<%= uploadsPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
          <% } %>
        </div>
      </div>
    <% } %>

    <% if (report) { %>
      <h3>Resumen PxP</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Escuelas en XML</h3>
          <p><%= report.summary.totalEscuelas %></p>
        </article>
        <article class="stat-card">
          <h3>Total docentes</h3>
          <p><%= report.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Total plazas</h3>
          <p><%= report.summary.totalPlazas %></p>
        </article>
      </div>

      <h3>Vista previa PxP - Docentes y plazas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Num. Empleado</th>
              <th>Nombre</th>
              <th>Dictamen</th>
              <th>Turno</th>
              <th>Horas Nom.</th>
              <th>Horas Carga</th>
              <th>Horas Descarga</th>
              <th>Total Plazas</th>
            </tr>
          </thead>
          <tbody>
            <% report.docentesPreview.forEach((docente) => { %>
              <tr>
                <td><%= docente.rfc || '-' %></td>
                <td><%= docente.numEmp || '-' %></td>
                <td><%= docente.nombre || '-' %></td>
                <td><%= docente.dictamen || '-' %></td>
                <td><%= docente.turno || '-' %></td>
                <td><%= docente.horasNombramiento || '-' %></td>
                <td><%= docente.horasCarga || '-' %></td>
                <td><%= docente.horasDescarga || '-' %></td>
                <td><%= docente.plazas.length %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (report.previewPagination && report.previewPagination.totalItems > 0) { %>
        <div class="row-between pager">
          <span class="pager-meta">
            Mostrando <%= report.previewPagination.startItem %>-<%= report.previewPagination.endItem %> de <%= report.previewPagination.totalItems %> docentes
            (pagina <%= report.previewPagination.currentPage %> de <%= report.previewPagination.totalPages %>)
          </span>
          <div class="pager-actions">
            <% if (report.previewPagination.hasPrev) { %>
              <a href="<%= report.previewPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
            <% } %>
            <% if (report.previewPagination.hasNext) { %>
              <a href="<%= report.previewPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } %>

    <% if (mxgReport) { %>
      <h3>Resumen MXG</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Registros de horario</h3>
          <p><%= mxgReport.summary.totalRegistros %></p>
        </article>
        <article class="stat-card">
          <h3>Docentes en MXG</h3>
          <p><%= mxgReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Solicitudes de horas</h3>
          <p><%= mxgReport.summary.totalSolicitudesAdicionales %></p>
        </article>
      </div>

      <h3>Vista previa MXG - Solicitudes de horas adicionales</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Asignatura</th>
              <th>Grupo</th>
              <th>Horas necesarias</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% mxgReport.additionalPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.asignaturaDesc || '-' %></td>
                <td><%= item.grupo || '-' %></td>
                <td><%= item.hrsNecesarias %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (mxgReport.previewPagination && mxgReport.previewPagination.totalItems > 0) { %>
        <div class="row-between pager">
          <span class="pager-meta">
            Mostrando <%= mxgReport.previewPagination.startItem %>-<%= mxgReport.previewPagination.endItem %> de <%= mxgReport.previewPagination.totalItems %> solicitudes
            (pagina <%= mxgReport.previewPagination.currentPage %> de <%= mxgReport.previewPagination.totalPages %>)
          </span>
          <div class="pager-actions">
            <% if (mxgReport.previewPagination.hasPrev) { %>
              <a href="<%= mxgReport.previewPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
            <% } %>
            <% if (mxgReport.previewPagination.hasNext) { %>
              <a href="<%= mxgReport.previewPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } %>

    <% if (historicoReport) { %>
      <h3>Resumen HISTORICO</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Escuelas en HISTORICO</h3>
          <p><%= historicoReport.summary.totalEscuelas %></p>
        </article>
        <article class="stat-card">
          <h3>Docentes identificados</h3>
          <p><%= historicoReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Asignaturas historicas</h3>
          <p><%= historicoReport.summary.totalAsignaturas %></p>
        </article>
      </div>

      <h3>Vista previa de asignaturas historicas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Num. Empleado</th>
              <th>Nombre</th>
              <th>Ciclo</th>
              <th>Asignatura</th>
              <th>Carrera</th>
              <th>Turno</th>
            </tr>
          </thead>
          <tbody>
            <% historicoReport.subjectsPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.numEmp || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.cicloDescripcion || '-' %></td>
                <td><%= item.asignaturaDescripcion || '-' %></td>
                <td><%= item.carreraDescripcion || '-' %></td>
                <td><%= item.turno || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (historicoReport.previewPagination && historicoReport.previewPagination.totalItems > 0) { %>
        <div class="row-between pager">
          <span class="pager-meta">
            Mostrando <%= historicoReport.previewPagination.startItem %>-<%= historicoReport.previewPagination.endItem %> de <%= historicoReport.previewPagination.totalItems %> asignaturas
            (pagina <%= historicoReport.previewPagination.currentPage %> de <%= historicoReport.previewPagination.totalPages %>)
          </span>
          <div class="pager-actions">
            <% if (historicoReport.previewPagination.hasPrev) { %>
              <a href="<%= historicoReport.previewPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
            <% } %>
            <% if (historicoReport.previewPagination.hasNext) { %>
              <a href="<%= historicoReport.previewPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } %>

    <% if (ruaaReport) { %>
      <h3>Resumen RUAA</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Docentes RUAA</h3>
          <p><%= ruaaReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Horarios de clase</h3>
          <p><%= ruaaReport.summary.totalHorarios %></p>
        </article>
        <article class="stat-card">
          <h3>Actividades adicionales</h3>
          <p><%= ruaaReport.summary.totalActividades %></p>
        </article>
      </div>

      <h3>Vista previa RUAA - Clases impartidas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Asignatura</th>
              <th>Grupo</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% ruaaReport.classPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.asignaturaDescripcion || '-' %></td>
                <td><%= item.grupo || '-' %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (ruaaReport.classPreviewPagination && ruaaReport.classPreviewPagination.totalItems > 0) { %>
        <div class="row-between pager pager-compact">
          <span class="pager-meta">
            Mostrando <%= ruaaReport.classPreviewPagination.startItem %>-<%= ruaaReport.classPreviewPagination.endItem %> de <%= ruaaReport.classPreviewPagination.totalItems %> clases
            (pagina <%= ruaaReport.classPreviewPagination.currentPage %> de <%= ruaaReport.classPreviewPagination.totalPages %>)
          </span>
          <div class="pager-actions">
            <% if (ruaaReport.classPreviewPagination.hasPrev) { %>
              <a href="<%= ruaaReport.classPreviewPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
            <% } %>
            <% if (ruaaReport.classPreviewPagination.hasNext) { %>
              <a href="<%= ruaaReport.classPreviewPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
            <% } %>
          </div>
        </div>
      <% } %>

      <h3>Vista previa RUAA - Actividades adicionales</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Actividad</th>
              <th>Lugar</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% ruaaReport.activityPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.actividadNombre || '-' %></td>
                <td><%= item.lugarActividad || '-' %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (ruaaReport.activityPreviewPagination && ruaaReport.activityPreviewPagination.totalItems > 0) { %>
        <div class="row-between pager">
          <span class="pager-meta">
            Mostrando <%= ruaaReport.activityPreviewPagination.startItem %>-<%= ruaaReport.activityPreviewPagination.endItem %> de <%= ruaaReport.activityPreviewPagination.totalItems %> actividades
            (pagina <%= ruaaReport.activityPreviewPagination.currentPage %> de <%= ruaaReport.activityPreviewPagination.totalPages %>)
          </span>
          <div class="pager-actions">
            <% if (ruaaReport.activityPreviewPagination.hasPrev) { %>
              <a href="<%= ruaaReport.activityPreviewPagination.prevHref %>" class="btn btn-secondary">Anterior</a>
            <% } %>
            <% if (ruaaReport.activityPreviewPagination.hasNext) { %>
              <a href="<%= ruaaReport.activityPreviewPagination.nextHref %>" class="btn btn-secondary">Siguiente</a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } %>

    <section class="feature-item" style="margin-top:1rem; border-left-width:5px;">
      <h3>Consulta de datos con IA</h3>
      <p>Haz preguntas directas sobre docentes y tecnicos por escuela en una pagina dedicada.</p>
      <a class="btn btn-secondary" href="<%= basePath %>/analista/ia">Ir a Consulta IA</a>
    </section>
  </section>
</main>

<script>
  (function () {
    const forms = document.querySelectorAll('.js-upload-form');
    forms.forEach(function (form) {
      form.addEventListener('submit', function () {
        const submitButton = form.querySelector('.js-upload-submit');
        if (!submitButton) {
          return;
        }

        // Evita dobles envios y muestra estado de trabajo en curso.
        submitButton.disabled = true;
        submitButton.classList.add('is-loading');
        submitButton.setAttribute('aria-busy', 'true');
      });
    });

  })();
</script>

<%- include('partials/foot') %>
