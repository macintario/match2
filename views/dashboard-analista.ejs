<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="main-content">
  <section class="card">
    <div class="row-between">
      <div>
        <h1>Panel Analista</h1>
        <p>Funciones habilitadas para el perfil Analista.</p>
      </div>
    </div>

    <form method="GET" action="<%= basePath %>/analista" style="margin:0.75rem 0 1rem 0; display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
      <div style="display:flex; flex-direction:column; gap:0.25rem;">
        <label for="school-key" style="font-size:0.85rem; font-weight:600; color:#555;">Escuela de trabajo</label>
        <select id="school-key" name="schoolKey" class="form-control" style="min-width:280px;" <%= !schoolOptions || schoolOptions.length === 0 ? 'disabled' : '' %>>
          <% if (!schoolOptions || schoolOptions.length === 0) { %>
            <option value="">No hay escuelas disponibles</option>
          <% } %>
          <% (schoolOptions || []).forEach(function(opt) { %>
            <option value="<%= opt.key %>" <%= activeSchoolKey === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary" <%= !schoolOptions || schoolOptions.length === 0 ? 'disabled' : '' %>>Cambiar escuela</button>
    </form>

    <h3>
      Reporte de horas solicitadas por academia
      <% if (escuelaHorasSolicitadas) { %>
        - <%= escuelaHorasSolicitadas %>
      <% } %>
    </h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Academia</th>
            <th>Solicitudes</th>
            <th>Horas solicitadas</th>
          </tr>
        </thead>
        <tbody>
          <% if (!horasSolicitadasPorAcademia || horasSolicitadasPorAcademia.length === 0) { %>
            <tr>
              <td colspan="3">No hay solicitudes de horas adicionales para reportar.</td>
            </tr>
          <% } %>
          <% (horasSolicitadasPorAcademia || []).forEach((item, index) => {
               const detailId = `academia-drilldown-${index}`;
               const detailRows = (detalleSolicitudesPorAcademia && detalleSolicitudesPorAcademia[item.academiaDesc]) || [];
          %>
            <tr>
              <td>
                <button
                  type="button"
                  class="drilldown-academia-btn"
                  data-drilldown-target="<%= detailId %>"
                  aria-expanded="false"
                  style="border:0; background:transparent; color:var(--primary); cursor:pointer; font:inherit; padding:0; text-decoration:underline;"
                >
                  <%= item.academiaDesc %>
                </button>
              </td>
              <td><%= item.totalSolicitudes %></td>
              <td><%= item.totalHorasSolicitadas %></td>
            </tr>
            <tr id="<%= detailId %>" class="drilldown-detail-row" style="display:none;">
              <td colspan="3" style="background:#fff6f8;">
                <strong>Detalle de solicitudes</strong>
                <div class="table-wrap" style="margin-top:8px;">
                  <table>
                    <thead>
                      <tr>
                        <th>Materia</th>
                        <th>Docente</th>
                        <th>Grupo</th>
                        <th>Horas solicitadas</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (!detailRows.length) { %>
                        <tr>
                          <td colspan="4">No hay detalle disponible para esta academia.</td>
                        </tr>
                      <% } %>
                      <% detailRows.forEach((detail) => { %>
                        <tr>
                          <td><%= detail.asignaturaDesc %></td>
                          <td><%= detail.docente %></td>
                          <td><%= detail.grupo %></td>
                          <td><%= detail.horasSolicitadas %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (horasSolicitadasPorAcademia && horasSolicitadasPorAcademia.length > 0) { %>
            <tr>
              <td><strong>Total general</strong></td>
              <td><strong><%= horasSolicitadasTotales.totalSolicitudes %></strong></td>
              <td><strong><%= horasSolicitadasTotales.totalHorasSolicitadas %></strong></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <script>
      (function () {
        const buttons = document.querySelectorAll('.drilldown-academia-btn');
        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            const targetId = btn.getAttribute('data-drilldown-target');
            const target = document.getElementById(targetId);
            if (!target) {
              return;
            }
            const isOpen = target.style.display !== 'none';
            target.style.display = isOpen ? 'none' : 'table-row';
            btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          });
        });
      })();
    </script>

    <div class="feature-list">
      <div class="feature-item">
        <h3>Consulta de datos con IA</h3>
        <p>Pregunta por conteos y resumenes de datos por escuela.</p>
        <a class="btn btn-secondary" href="<%= basePath %>/analista/ia">Abrir consulta IA</a>
      </div>
      <div class="feature-item">
        <h3>Consulta de indicadores</h3>
        <p>Acceso a reportes y resumenes de desempeno.</p>
      </div>
      <div class="feature-item">
        <h3>Analisis operacional</h3>
        <p>Visualizacion y seguimiento de datos clave.</p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
