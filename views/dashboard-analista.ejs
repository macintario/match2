<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="main-content">
  <section class="card">
    <div class="row-between">
      <div>
        <h1>Panel Analista</h1>
        <p>Funciones habilitadas para el perfil Analista.</p>
      </div>
      <a href="<%= basePath %>/analista/cargas" class="btn btn-primary">Ir a carga de archivos</a>
    </div>

    <h3>Registro de cargas</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Tipo</th>
            <th>Archivo</th>
            <th>Fecha y hora</th>
            <th>Usuario</th>
            <th>Escuelas</th>
            <th>Docentes</th>
            <th>Plazas</th>
            <th>Asignaturas</th>
            <th>Horarios</th>
            <th>Actividades</th>
            <th>Solicitudes Hrs Adic.</th>
          </tr>
        </thead>
        <tbody>
          <% if (!recentUploads || recentUploads.length === 0) { %>
            <tr>
              <td colspan="12">Aun no hay cargas registradas.</td>
            </tr>
          <% } %>
          <% (recentUploads || []).forEach((upload) => { %>
            <tr>
              <td><%= upload.id %></td>
              <td><%= upload.uploadType || 'PXP' %></td>
              <td><%= upload.originalFileName %></td>
              <td><%= new Date(upload.uploadedAt).toLocaleString('es-MX') %></td>
              <td><%= upload.User ? upload.User.name : '-' %></td>
              <td><%= upload.totalEscuelas %></td>
              <td><%= upload.totalDocentes %></td>
              <td><%= upload.totalPlazas %></td>
              <td><%= upload.totalAsignaturas || 0 %></td>
              <td><%= upload.totalHorarios || 0 %></td>
              <td><%= upload.totalActividades || 0 %></td>
              <td><%= upload.totalSolicitudesAdicionales || 0 %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <h3>
      Reporte de horas solicitadas por academia
      <% if (escuelaHorasSolicitadas) { %>
        - <%= escuelaHorasSolicitadas %>
      <% } %>
    </h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Academia</th>
            <th>Solicitudes</th>
            <th>Horas solicitadas</th>
          </tr>
        </thead>
        <tbody>
          <% if (!horasSolicitadasPorAcademia || horasSolicitadasPorAcademia.length === 0) { %>
            <tr>
              <td colspan="3">No hay solicitudes de horas adicionales para reportar.</td>
            </tr>
          <% } %>
          <% (horasSolicitadasPorAcademia || []).forEach((item) => { %>
            <tr>
              <td><%= item.academiaDesc %></td>
              <td><%= item.totalSolicitudes %></td>
              <td><%= item.totalHorasSolicitadas %></td>
            </tr>
          <% }) %>
          <% if (horasSolicitadasPorAcademia && horasSolicitadasPorAcademia.length > 0) { %>
            <tr>
              <td><strong>Total general</strong></td>
              <td><strong><%= horasSolicitadasTotales.totalSolicitudes %></strong></td>
              <td><strong><%= horasSolicitadasTotales.totalHorasSolicitadas %></strong></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <h3>Histograma de Horas por Cubrir (hrsXCub) — PxP</h3>
    <% if (!hrsXCubHistogram || hrsXCubHistogram.length === 0) { %>
      <p>No hay datos de hrsXCub disponibles. Carga un archivo PxP primero.</p>
    <% } else { %>
      <div style="overflow-x:auto;">
        <canvas id="hrsXCubChart" height="320" style="max-width:100%;"></canvas>
      </div>
      <script>
        (function () {
          const data = <%- JSON.stringify(hrsXCubHistogram) %>;
          const labels = data.map(function(d) { return d.valor === '' ? '(vacío)' : d.valor; });
          const values = data.map(function(d) { return d.cantidad; });
          const maxVal = Math.max.apply(null, values) || 1;

          const canvas = document.getElementById('hrsXCubChart');
          const ctx = canvas.getContext('2d');

          const BAR_W = 48;
          const GAP = 12;
          const PADDING_LEFT = 60;
          const PADDING_RIGHT = 20;
          const PADDING_TOP = 30;
          const PADDING_BOTTOM = 70;

          canvas.width = PADDING_LEFT + (BAR_W + GAP) * labels.length + PADDING_RIGHT;
          const CHART_H = canvas.height - PADDING_TOP - PADDING_BOTTOM;

          ctx.clearRect(0, 0, canvas.width, canvas.height);

          // Fondo
          ctx.fillStyle = '#f8f9fa';
          ctx.fillRect(0, 0, canvas.width, canvas.height);

          // Eje Y — líneas guía
          const Y_TICKS = 5;
          ctx.strokeStyle = '#dee2e6';
          ctx.lineWidth = 1;
          ctx.fillStyle = '#555';
          ctx.font = '11px sans-serif';
          ctx.textAlign = 'right';
          for (let i = 0; i <= Y_TICKS; i++) {
            const y = PADDING_TOP + CHART_H - (CHART_H / Y_TICKS) * i;
            const tickVal = Math.round((maxVal / Y_TICKS) * i);
            ctx.beginPath();
            ctx.moveTo(PADDING_LEFT - 5, y);
            ctx.lineTo(canvas.width - PADDING_RIGHT, y);
            ctx.stroke();
            ctx.fillText(tickVal, PADDING_LEFT - 8, y + 4);
          }

          // Eje Y label
          ctx.save();
          ctx.translate(14, PADDING_TOP + CHART_H / 2);
          ctx.rotate(-Math.PI / 2);
          ctx.textAlign = 'center';
          ctx.fillStyle = '#333';
          ctx.font = '12px sans-serif';
          ctx.fillText('Docentes', 0, 0);
          ctx.restore();

          // Barras
          data.forEach(function (d, i) {
            const barH = (d.cantidad / maxVal) * CHART_H;
            const x = PADDING_LEFT + i * (BAR_W + GAP);
            const y = PADDING_TOP + CHART_H - barH;

            // Color por signo
            const num = parseFloat(d.valor);
            ctx.fillStyle = isNaN(num) ? '#adb5bd' : (num < 0 ? '#e55353' : num === 0 ? '#6c757d' : '#4a9eff');

            ctx.fillRect(x, y, BAR_W, barH);

            // Valor encima de la barra
            ctx.fillStyle = '#333';
            ctx.font = '11px sans-serif';
            ctx.textAlign = 'center';
            if (barH > 14) {
              ctx.fillText(d.cantidad, x + BAR_W / 2, y - 4);
            } else {
              ctx.fillText(d.cantidad, x + BAR_W / 2, y - 4);
            }

            // Etiqueta eje X
            ctx.save();
            ctx.translate(x + BAR_W / 2, PADDING_TOP + CHART_H + 8);
            ctx.rotate(Math.PI / 4);
            ctx.textAlign = 'left';
            ctx.fillStyle = '#444';
            ctx.font = '11px sans-serif';
            ctx.fillText(labels[i], 0, 0);
            ctx.restore();
          });

          // Eje X label
          ctx.textAlign = 'center';
          ctx.fillStyle = '#333';
          ctx.font = '12px sans-serif';
          ctx.fillText('hrsXCub', canvas.width / 2, canvas.height - 4);
        })();
      </script>
    <% } %>

    <% if (report) { %>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Escuelas en XML</h3>
          <p><%= report.summary.totalEscuelas %></p>
        </article>
        <article class="stat-card">
          <h3>Total docentes</h3>
          <p><%= report.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Total plazas</h3>
          <p><%= report.summary.totalPlazas %></p>
        </article>
      </div>

      <div class="feature-list">
        <% report.schools.forEach((school) => { %>
          <div class="feature-item">
            <h3><%= school.plantel || 'Plantel sin descripcion' %></h3>
            <p>Plantel ID: <%= school.plantelId || '-' %> | Ciclo: <%= school.cicloId || '-' %> | Usuario: <%= school.usuario || '-' %></p>
            <p>Docentes: <strong><%= school.docentes.length %></strong></p>
          </div>
        <% }) %>
      </div>

      <h3>Docentes y plazas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Num. Empleado</th>
              <th>Nombre</th>
              <th>Dictamen</th>
              <th>Turno</th>
              <th>Horas Nom.</th>
              <th>Horas Carga</th>
              <th>Horas Descarga</th>
              <th>Total Plazas</th>
            </tr>
          </thead>
          <tbody>
            <% report.docentes.forEach((docente) => { %>
              <tr>
                <td><%= docente.rfc || '-' %></td>
                <td><%= docente.numEmp || '-' %></td>
                <td><%= docente.nombre || '-' %></td>
                <td><%= docente.dictamen || '-' %></td>
                <td><%= docente.turno || '-' %></td>
                <td><%= docente.horasNombramiento || '-' %></td>
                <td><%= docente.horasCarga || '-' %></td>
                <td><%= docente.horasDescarga || '-' %></td>
                <td><%= docente.plazas.length %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (mxgReport) { %>
      <h3>Resumen MXG</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Registros de horario</h3>
          <p><%= mxgReport.summary.totalRegistros %></p>
        </article>
        <article class="stat-card">
          <h3>Docentes en MXG</h3>
          <p><%= mxgReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Solicitudes de horas</h3>
          <p><%= mxgReport.summary.totalSolicitudesAdicionales %></p>
        </article>
      </div>

      <h3>Solicitudes de horas adicionales (HRSNECESARIAS != 0)</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Asignatura</th>
              <th>Grupo</th>
              <th>Horas necesarias</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% mxgReport.additionalPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.asignaturaDesc || '-' %></td>
                <td><%= item.grupo || '-' %></td>
                <td><%= item.hrsNecesarias %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (mxgReport.previewTruncated) { %>
        <p>Se muestran los primeros 120 registros de MXG en cada tabla.</p>
      <% } %>
    <% } %>

    <% if (historicoReport) { %>
      <h3>Resumen HISTORICO</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Escuelas en HISTORICO</h3>
          <p><%= historicoReport.summary.totalEscuelas %></p>
        </article>
        <article class="stat-card">
          <h3>Docentes identificados</h3>
          <p><%= historicoReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Asignaturas historicas</h3>
          <p><%= historicoReport.summary.totalAsignaturas %></p>
        </article>
      </div>

      <h3>Vista previa de asignaturas historicas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Num. Empleado</th>
              <th>Nombre</th>
              <th>Ciclo</th>
              <th>Asignatura</th>
              <th>Carrera</th>
              <th>Turno</th>
            </tr>
          </thead>
          <tbody>
            <% historicoReport.subjectsPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.numEmp || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.cicloDescripcion || '-' %></td>
                <td><%= item.asignaturaDescripcion || '-' %></td>
                <td><%= item.carreraDescripcion || '-' %></td>
                <td><%= item.turno || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (historicoReport.previewTruncated) { %>
        <p>Se muestran los primeros 120 registros de asignaturas.</p>
      <% } %>
    <% } %>

    <% if (ruaaReport) { %>
      <h3>Resumen RUAA</h3>
      <div class="stats-grid">
        <article class="stat-card">
          <h3>Docentes RUAA</h3>
          <p><%= ruaaReport.summary.totalDocentes %></p>
        </article>
        <article class="stat-card">
          <h3>Horarios de clase</h3>
          <p><%= ruaaReport.summary.totalHorarios %></p>
        </article>
        <article class="stat-card">
          <h3>Actividades adicionales</h3>
          <p><%= ruaaReport.summary.totalActividades %></p>
        </article>
      </div>

      <h3>Vista previa RUAA - Clases impartidas</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Asignatura</th>
              <th>Grupo</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% ruaaReport.classPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.asignaturaDescripcion || '-' %></td>
                <td><%= item.grupo || '-' %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <h3>Vista previa RUAA - Actividades adicionales</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>RFC</th>
              <th>Docente</th>
              <th>Actividad</th>
              <th>Lugar</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miercoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
            </tr>
          </thead>
          <tbody>
            <% ruaaReport.activityPreview.forEach((item) => { %>
              <tr>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.actividadNombre || '-' %></td>
                <td><%= item.lugarActividad || '-' %></td>
                <td><%= item.lunes || '-' %></td>
                <td><%= item.martes || '-' %></td>
                <td><%= item.miercoles || '-' %></td>
                <td><%= item.jueves || '-' %></td>
                <td><%= item.viernes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (ruaaReport.previewTruncated) { %>
        <p>Se muestran los primeros 80 registros de cada seccion RUAA.</p>
      <% } %>
    <% } %>

    <div class="feature-list">
      <div class="feature-item">
        <h3>Consulta de indicadores</h3>
        <p>Acceso a reportes y resumenes de desempeno.</p>
      </div>
      <div class="feature-item">
        <h3>Analisis operacional</h3>
        <p>Visualizacion y seguimiento de datos clave.</p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
