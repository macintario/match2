<header class="topbar">
  <a href="<%= basePath %>/dashboard" class="brand">Control de Accesos</a>

  <% if (currentUser) { %>
    <nav class="topnav">
      <span class="badge"><%= currentUser.role %></span>
      <span class="username"><%= currentUser.name %></span>
      <% if (currentUser.role === 'admin') { %>
        <a href="<%= basePath %>/admin/users">Usuarios</a>
      <% } %>
      <form action="<%= basePath %>/logout" method="POST" class="inline-form">
        <button type="submit" class="btn btn-ghost">Cerrar sesion</button>
      </form>
    </nav>
  <% } %>
</header>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
<% } %>
