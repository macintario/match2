<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="main-content">
  <section class="card">
    <div class="row-between">
      <div>
        <h1>Analitica </h1>
      </div>
      <a href="<%= basePath %>/analista" class="btn btn-secondary">Volver al panel</a>
    </div>

    <form id="school-filter-form" method="GET" action="<%= basePath %>/analista/analitica" style="margin:0.75rem 0 1rem 0; display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
      <div style="display:flex; flex-direction:column; gap:0.25rem;">
        <label for="school-key" style="font-size:0.85rem; font-weight:600; color:#555;">Escuela de trabajo</label>
        <select id="school-key" name="schoolKey" class="form-control" style="min-width:280px;">
          <% if (!schoolOptions || schoolOptions.length === 0) { %>
            <option value="">No hay escuelas disponibles</option>
          <% } %>
          <% (schoolOptions || []).forEach(function(opt) { %>
            <option value="<%= opt.key %>" <%= activeSchoolKey === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary" id="school-submit-btn">
        <span>Cambiar escuela</span>
        <div class="btn-spinner"></div>
      </button>
    </form>

    <script>
      (function() {
        const form = document.getElementById('school-filter-form');
        const btn = document.getElementById('school-submit-btn');
        if (form && btn) {
          form.addEventListener('submit', function() {
            btn.classList.add('is-loading');
            btn.disabled = true;
          });
        }
      })();
    </script>

    <% if (activeSchoolLabel) { %>
      <p><strong>Escuela:</strong> <%= escuelaHorasSolicitadas %></p>
    <% } else { %>
      <p style="color:#8a6d3b;">Selecciona una escuela para consultar analitica y reportes.</p>
    <% } %>

    <h3>Edad de docentes por academia</h3>
    <% if (!academiaAgeRiskReport) { %>
      <p>Sin datos para generar la relacion entre academias y edades. Carga PxP y MXG para la escuela activa.</p>
    <% } else if (!academiaAgeRiskReport.teacherAgesForChart || academiaAgeRiskReport.teacherAgesForChart.length === 0) { %>
      <p>No se pudieron calcular edades validas desde RFC para los docentes del conjunto filtrado.</p>
    <% } else { %>
      <p>
        <strong>Academias:</strong> <%= academiaAgeRiskReport.totalAcademias %>
        | <strong>Docentes con edad calculada:</strong> <%= academiaAgeRiskReport.totalDocentesConEdad %>
        | <strong>Riesgo alto:</strong> <%= academiaAgeRiskReport.academiasConRiesgoAlto %>
        | <strong>Riesgo medio:</strong> <%= academiaAgeRiskReport.academiasConRiesgoMedio %>
      </p>
      <p>
        Criterio de riesgo: <strong>edad avanzada</strong> = <%= academiaAgeRiskReport.seniorAgeThreshold %> o mas.
        Se considera <strong>riesgo alto</strong> si la academia tiene docentes de edad avanzada y ningun docente menor de
        <%= academiaAgeRiskReport.youngAgeThreshold %> anos; <strong>riesgo medio</strong> si solo tiene uno menor de ese umbral.
      </p>

      <% const exportAcademiaAgeParams = []; %>
      <% if (activeSchoolKey) exportAcademiaAgeParams.push(`schoolKey=${encodeURIComponent(activeSchoolKey)}`); %>
      <% if (filterSemNivel && hasSemNivelField) exportAcademiaAgeParams.push(`semNivel=${encodeURIComponent(filterSemNivel)}`); %>
      <% if (filterAcademia) exportAcademiaAgeParams.push(`academia=${encodeURIComponent(filterAcademia)}`); %>
      <% if (filterAsigTipo && hasAsigTipoField) exportAcademiaAgeParams.push(`asigTipo=${encodeURIComponent(filterAsigTipo)}`); %>
      <% if (filterModalidad) exportAcademiaAgeParams.push(`modalidad=${encodeURIComponent(filterModalidad)}`); %>
      <% if (filterCarreraDesc) exportAcademiaAgeParams.push(`carreraDesc=${encodeURIComponent(filterCarreraDesc)}`); %>
      <% const exportAcademiaAgeQuery = exportAcademiaAgeParams.length ? `?${exportAcademiaAgeParams.join('&')}` : ''; %>
      <div style="margin-bottom:10px;">
        <a href="<%= basePath %>/analista/analitica/export-academia-age-risk-csv<%= exportAcademiaAgeQuery %>" class="btn btn-secondary">Descargar reporte CSV</a>
      </div>

      <div style="overflow-x:auto; margin-bottom:1rem;">
        <canvas id="academiaAgeChart" height="360" style="max-width:100%;"></canvas>
      </div>

      <script>
        (function () {
          const data = <%- JSON.stringify(academiaAgeRiskReport.teacherAgesForChart || []) %>;
          const academias = Array.from(new Set(data.map(function (item) { return item.academiaDesc || 'Sin academia'; })));
          const canvas = document.getElementById('academiaAgeChart');
          if (!canvas || academias.length === 0) {
            return;
          }

          const ctx = canvas.getContext('2d');
          const rowHeight = 56;
          const chartHeight = Math.max(240, academias.length * rowHeight);
          const paddingTop = 24;
          const paddingBottom = 28;
          const paddingLeft = 260;
          const paddingRight = 28;
          const chartWidth = 760;
          const maxAge = Math.max.apply(null, data.map(function (item) { return Number(item.edad || 0); })) || 80;
          const minAge = Math.min.apply(null, data.map(function (item) { return Number(item.edad || 0); })) || 20;
          const xMin = Math.max(18, Math.floor(minAge / 5) * 5 - 5);
          const xMax = Math.max(xMin + 10, Math.ceil(maxAge / 5) * 5 + 5);
          const plottedPoints = [];
          const pointRadiusBase = 4.5;
          const collisionPadding = 1.5;
          const swarmStep = Math.max(4.5, pointRadiusBase * 1.45);
          const maxOffsetPerRow = rowHeight * 0.42;
          const rawPointsByAcademia = academias.map(function () { return []; });

          canvas.width = paddingLeft + chartWidth + paddingRight;
          canvas.height = paddingTop + chartHeight + paddingBottom;

          const tooltip = document.createElement('div');
          tooltip.style.position = 'fixed';
          tooltip.style.pointerEvents = 'none';
          tooltip.style.background = 'rgba(31, 35, 40, 0.96)';
          tooltip.style.color = '#fff';
          tooltip.style.padding = '8px 10px';
          tooltip.style.borderRadius = '8px';
          tooltip.style.font = '12px sans-serif';
          tooltip.style.lineHeight = '1.35';
          tooltip.style.boxShadow = '0 10px 24px rgba(0, 0, 0, 0.18)';
          tooltip.style.zIndex = '9999';
          tooltip.style.display = 'none';
          document.body.appendChild(tooltip);

          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle = '#f8f9fa';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          ctx.font = '12px sans-serif';

          for (let tick = xMin; tick <= xMax; tick += 5) {
            const x = paddingLeft + ((tick - xMin) / (xMax - xMin)) * chartWidth;
            ctx.strokeStyle = tick === 60 ? '#d94841' : '#dde2e7';
            ctx.lineWidth = tick === 60 ? 2 : 1;
            ctx.beginPath();
            ctx.moveTo(x, paddingTop);
            ctx.lineTo(x, paddingTop + chartHeight);
            ctx.stroke();

            ctx.fillStyle = tick === 60 ? '#a61e1e' : '#57606a';
            ctx.textAlign = 'center';
            ctx.fillText(String(tick), x, paddingTop + chartHeight + 18);
          }

          academias.forEach(function (academia, index) {
            const y = paddingTop + index * rowHeight + rowHeight / 2;
            ctx.strokeStyle = '#eef1f4';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(paddingLeft, y + rowHeight / 2 - 2);
            ctx.lineTo(paddingLeft + chartWidth, y + rowHeight / 2 - 2);
            ctx.stroke();

            ctx.fillStyle = '#1f2328';
            ctx.textAlign = 'right';
            ctx.fillText(academia.length > 36 ? academia.slice(0, 33) + '...' : academia, paddingLeft - 12, y + 4);
          });

          function buildOffsetCandidates(maxOffset, step) {
            const candidates = [0];
            const levels = Math.max(1, Math.floor(maxOffset / step));
            for (let i = 1; i <= levels; i += 1) {
              const value = i * step;
              candidates.push(value);
              candidates.push(-value);
            }
            return candidates;
          }

          const offsetCandidates = buildOffsetCandidates(maxOffsetPerRow, swarmStep);

          data.forEach(function (item) {
            const academiaIndex = academias.indexOf(item.academiaDesc || 'Sin academia');
            if (academiaIndex < 0) {
              return;
            }

            const age = Number(item.edad || 0);
            const x = paddingLeft + ((age - xMin) / (xMax - xMin)) * chartWidth;
            const color = age >= 60 ? '#d94841' : age < 45 ? '#2b8a3e' : '#2563eb';

            rawPointsByAcademia[academiaIndex].push({
              x: x,
              docente: item.docente || 'Docente sin nombre',
              edad: age,
              academia: item.academiaDesc || 'Sin academia',
              color: color,
            });
          });

          academias.forEach(function (_, academiaIndex) {
            const rowCenterY = paddingTop + academiaIndex * rowHeight + rowHeight / 2;
            const points = rawPointsByAcademia[academiaIndex]
              .slice()
              .sort(function (a, b) {
                if (a.x !== b.x) {
                  return a.x - b.x;
                }
                return String(a.docente || '').localeCompare(String(b.docente || ''), 'es', { sensitivity: 'base' });
              });

            const placed = [];

            points.forEach(function (point, pointIndex) {
              let chosenOffset = 0;
              let chosenRadius = pointRadiusBase;
              let found = false;

              for (let radiusTry = 0; radiusTry < 3 && !found; radiusTry += 1) {
                const candidateRadius = Math.max(2.6, pointRadiusBase - radiusTry * 0.8);

                for (let i = 0; i < offsetCandidates.length; i += 1) {
                  const candidateOffset = offsetCandidates[i];
                  const hasCollision = placed.some(function (existing) {
                    const dx = point.x - existing.x;
                    const dy = candidateOffset - existing.offset;
                    const minDist = candidateRadius + existing.radius + collisionPadding;
                    return (dx * dx + dy * dy) < (minDist * minDist);
                  });

                  if (!hasCollision) {
                    chosenOffset = candidateOffset;
                    chosenRadius = candidateRadius;
                    found = true;
                    break;
                  }
                }
              }

              if (!found) {
                chosenOffset = offsetCandidates[pointIndex % offsetCandidates.length] || 0;
                chosenRadius = 2.6;
              }

              const y = rowCenterY + chosenOffset;
              ctx.fillStyle = point.color;
              ctx.beginPath();
              ctx.arc(point.x, y, chosenRadius, 0, Math.PI * 2);
              ctx.fill();

              placed.push({
                x: point.x,
                offset: chosenOffset,
                radius: chosenRadius,
              });

              plottedPoints.push({
                x: point.x,
                y: y,
                radius: Math.max(9, chosenRadius + 4),
                drawRadius: chosenRadius,
                docente: point.docente,
                edad: point.edad,
                academia: point.academia,
              });
            });
          });

          ctx.fillStyle = '#1f2328';
          ctx.textAlign = 'center';
          ctx.fillText('Edad del docente', paddingLeft + chartWidth / 2, canvas.height - 4);

          function hideTooltip() {
            tooltip.style.display = 'none';
          }

          function showTooltip(point, clientX, clientY) {
            tooltip.innerHTML = '<strong>'
              + point.docente.replace(/</g, '&lt;').replace(/>/g, '&gt;')
              + '</strong><br>Edad: '
              + point.edad
              + '<br>Academia: '
              + point.academia.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            tooltip.style.display = 'block';
            tooltip.style.left = (clientX + 14) + 'px';
            tooltip.style.top = (clientY + 14) + 'px';
          }

          function findPointAtClientPosition(clientX, clientY) {
            const rect = canvas.getBoundingClientRect();
            const x = ((clientX - rect.left) / rect.width) * canvas.width;
            const y = ((clientY - rect.top) / rect.height) * canvas.height;

            return plottedPoints.find(function (item) {
              const dx = x - item.x;
              const dy = y - item.y;
              return Math.sqrt(dx * dx + dy * dy) <= item.radius;
            }) || null;
          }

          canvas.addEventListener('mousemove', function (event) {
            const point = findPointAtClientPosition(event.clientX, event.clientY);

            if (!point) {
              hideTooltip();
              canvas.style.cursor = 'default';
              return;
            }

            showTooltip(point, event.clientX, event.clientY);
            canvas.style.cursor = 'pointer';
          });

          canvas.addEventListener('click', function (event) {
            const point = findPointAtClientPosition(event.clientX, event.clientY);
            if (!point) {
              hideTooltip();
              canvas.style.cursor = 'default';
              return;
            }

            showTooltip(point, event.clientX, event.clientY);
            canvas.style.cursor = 'pointer';
          });

          canvas.addEventListener('touchstart', function (event) {
            const touch = event.touches && event.touches[0];
            if (!touch) {
              return;
            }

            const point = findPointAtClientPosition(touch.clientX, touch.clientY);
            if (!point) {
              hideTooltip();
              return;
            }

            showTooltip(point, touch.clientX, touch.clientY);
            event.preventDefault();
          }, { passive: false });

          document.addEventListener('touchstart', function (event) {
            if (canvas.contains(event.target)) {
              return;
            }
            hideTooltip();
          }, { passive: true });

          document.addEventListener('click', function (event) {
            if (canvas.contains(event.target)) {
              return;
            }
            hideTooltip();
          });

          canvas.addEventListener('mouseleave', function () {
            canvas.style.cursor = 'default';
            hideTooltip();
          });
        })();
      </script>

      <div class="table-wrap" style="margin-bottom:1rem;">
        <table>
          <thead>
            <tr>
              <th>Academia</th>
              <th>Riesgo</th>
              <th>Total docentes</th>
              <th>Con edad</th>
              <th>Sin edad</th>
              <th>Edad promedio</th>
              <th>Menor edad</th>
              <th>Mayor edad</th>
              <th>Docentes >= <%= academiaAgeRiskReport.seniorAgeThreshold %></th>
              <th>Docentes &lt; <%= academiaAgeRiskReport.youngAgeThreshold %></th>
            </tr>
          </thead>
          <tbody>
            <% academiaAgeRiskReport.rows.forEach(function(item) { %>
              <tr>
                <td><%= item.academiaDesc || '-' %></td>
                <td>
                  <span style="font-weight:700; color:<%= item.riskLevel === 'ALTO' ? '#a61e1e' : item.riskLevel === 'MEDIO' ? '#b26a00' : '#2b8a3e' %>;"><%= item.riskLevel %></span>
                </td>
                <td><%= item.totalDocentes %></td>
                <td><%= item.docentesConEdad %></td>
                <td><%= item.docentesSinEdad %></td>
                <td><%= item.averageAge !== null ? item.averageAge.toFixed(1) : '-' %></td>
                <td><%= item.youngestAge !== null ? item.youngestAge : '-' %></td>
                <td><%= item.oldestAge !== null ? item.oldestAge : '-' %></td>
                <td><%= item.seniorCount %></td>
                <td><%= item.youngCount %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <h3>Reporte: tecnicos docentes con carga</h3>
    <% if (!tecnicoDocentesConCargaReport) { %>
      <p>Sin datos para generar el reporte. Carga PxP y MXG para la escuela activa.</p>
    <% } else { %>
      <% if (!tecnicoDocentesConCargaReport.categorySourceAvailable) { %>
        <div class="alert alert-error">
          No se pudo consultar la tabla CATEG (CAT_SIMPLE).<br />
          Detalle: <%= tecnicoDocentesConCargaReport.categorySourceError || 'Sin detalle.' %>
        </div>
      <% } %>

      <p>
        <strong>Docentes:</strong> <%= tecnicoDocentesConCargaReport.totalDocentes %>
        | <strong>Suma HRSFTG:</strong> <%= tecnicoDocentesConCargaReport.totalHrsFtg %>
        | <strong>Suma HRSNECESARIAS:</strong> <%= tecnicoDocentesConCargaReport.totalHrsNecesarias %>
      </p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>NumEmp</th>
              <th>RFC</th>
              <th>Docente</th>
              <th>Categoria dictaminada</th>
              <th>Cat simple (dictamen)</th>
              <th>Categoria(s) plaza MXG</th>
              <th>Cat simple tecnico (plaza)</th>
              <th>HRSFTG</th>
              <th>HRSNECESARIAS</th>
              <th>Tecnico por</th>
            </tr>
          </thead>
          <tbody>
            <% if (!tecnicoDocentesConCargaReport.rows || tecnicoDocentesConCargaReport.rows.length === 0) { %>
              <tr>
                <td colspan="10">No hay tecnicos docentes con carga (HRSFTG o HRSNECESARIAS distinto de 0) para la escuela activa.</td>
              </tr>
            <% } %>
            <% (tecnicoDocentesConCargaReport.rows || []).forEach(function(item) { %>
              <tr>
                <td><%= item.numEmp || '-' %></td>
                <td><%= item.rfc || '-' %></td>
                <td><%= item.nombre || '-' %></td>
                <td><%= item.categoriaDictaminada %></td>
                <td><%= item.catSimpleDictamen %></td>
                <td><%= item.categoriaPlaza %></td>
                <td><%= item.catSimplePlaza %></td>
                <td><%= item.totalHrsFtg %></td>
                <td><%= item.totalHrsNecesarias %></td>
                <td>
                  <%= item.esTecnicoPorDictamen ? 'DICTAMEN' : '' %>
                  <%= item.esTecnicoPorDictamen && item.esTecnicoPorPlaza ? ' + ' : '' %>
                  <%= item.esTecnicoPorPlaza ? 'PLAZA' : '' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (mxgNeedsHoursWithoutHistoricalMatchReport) { %>
      <h3>Docentes con HRSNECESARIAS sin coincidencia en HIST</h3>
      <p>
        Se muestran registros de MXG con <strong>HRSNECESARIAS &gt; 0</strong> donde el docente no tiene
        coincidencia en HIST por materia, ni por area (academia MXG vs carrera HIST).
      </p>
      <% if (!mxgNeedsHoursWithoutHistoricalMatchReport.hasHistoricalSource) { %>
        <p style="color:#8a6d3b;">
          No hay una carga HIST para la escuela activa. Por eso los registros se marcan sin coincidencia.
        </p>
      <% } %>
      <p>
        <strong>Registros evaluados:</strong> <%= mxgNeedsHoursWithoutHistoricalMatchReport.totalRegistrosEvaluados %>
        | <strong>Docentes con HRSNECESARIAS:</strong> <%= mxgNeedsHoursWithoutHistoricalMatchReport.totalDocentesConHrsNecesarias %>
        | <strong>Registros sin coincidencia:</strong> <%= mxgNeedsHoursWithoutHistoricalMatchReport.totalRegistrosSinCoincidenciaHist %>
        | <strong>Docentes sin coincidencia:</strong> <%= mxgNeedsHoursWithoutHistoricalMatchReport.totalDocentesSinCoincidenciaHist %>
      </p>

      <div style="margin-bottom:10px;">
        <a href="<%= basePath %>/analista/analitica/export-hrs-necesarias-sin-hist-csv?schoolKey=<%= encodeURIComponent(activeSchoolKey || '') %>" class="btn btn-secondary">Descargar reporte CSV</a>
      </div>

      <% if (!mxgNeedsHoursWithoutHistoricalMatchReport.rows || mxgNeedsHoursWithoutHistoricalMatchReport.rows.length === 0) { %>
        <p style="color:#2d6a2d;">No se detectaron registros con HRSNECESARIAS sin coincidencia en HIST.</p>
      <% } else { %>
        <div class="table-wrap" style="margin-bottom:1rem;">
          <table>
            <thead>
              <tr>
                <th>Docente</th>
                <th>Num. Emp</th>
                <th>RFC</th>
                <th>Grupo</th>
                <th>Turno</th>
                <th>Carrera</th>
                <th>Materia MXG</th>
                <th>Academia MXG</th>
                <th>HRSNECESARIAS</th>
                <th>Registros HIST del docente</th>
                <th>Motivo</th>
              </tr>
            </thead>
            <tbody>
              <% mxgNeedsHoursWithoutHistoricalMatchReport.rows.forEach(function(item) { %>
                <tr>
                  <td><%= item.docente || '-' %></td>
                  <td><%= item.numEmp || '-' %></td>
                  <td><%= item.rfc || '-' %></td>
                  <td><%= item.grupo || '-' %></td>
                  <td><%= item.turno || '-' %></td>
                  <td><%= item.carreraDesc || '-' %></td>
                  <td><%= item.asignaturaDesc || '-' %></td>
                  <td><%= item.academiaDesc || '-' %></td>
                  <td><%= Number(item.hrsNecesarias || 0).toFixed(2) %></td>
                  <td><%= item.totalRegistrosHistDocente || 0 %></td>
                  <td><%= item.motivo || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>

    <h3>Histograma de Horas por Cubrir (hrsXCub) — PxP</h3>
    <% if (!hrsXCubHistogram || hrsXCubHistogram.length === 0) { %>
      <p>No hay datos de hrsXCub disponibles. Carga un archivo PxP primero.</p>
    <% } else { %>
      <div style="overflow-x:auto;">
        <canvas id="hrsXCubChart" height="320" style="max-width:100%;"></canvas>
      </div>
      <script>
        (function () {
          const data = <%- JSON.stringify(hrsXCubHistogram) %>;
          const labels = data.map(function(d) { return d.valor === '' ? '(vacío)' : d.valor; });
          const values = data.map(function(d) { return d.cantidad; });
          const maxVal = Math.max.apply(null, values) || 1;

          const canvas = document.getElementById('hrsXCubChart');
          const ctx = canvas.getContext('2d');

          const BAR_W = 48;
          const GAP = 12;
          const PADDING_LEFT = 60;
          const PADDING_RIGHT = 20;
          const PADDING_TOP = 30;
          const PADDING_BOTTOM = 70;

          canvas.width = PADDING_LEFT + (BAR_W + GAP) * labels.length + PADDING_RIGHT;
          const CHART_H = canvas.height - PADDING_TOP - PADDING_BOTTOM;

          ctx.clearRect(0, 0, canvas.width, canvas.height);

          ctx.fillStyle = '#f8f9fa';
          ctx.fillRect(0, 0, canvas.width, canvas.height);

          const Y_TICKS = 5;
          ctx.strokeStyle = '#dee2e6';
          ctx.lineWidth = 1;
          ctx.fillStyle = '#555';
          ctx.font = '11px sans-serif';
          ctx.textAlign = 'right';
          for (let i = 0; i <= Y_TICKS; i++) {
            const y = PADDING_TOP + CHART_H - (CHART_H / Y_TICKS) * i;
            const tickVal = Math.round((maxVal / Y_TICKS) * i);
            ctx.beginPath();
            ctx.moveTo(PADDING_LEFT - 5, y);
            ctx.lineTo(canvas.width - PADDING_RIGHT, y);
            ctx.stroke();
            ctx.fillText(tickVal, PADDING_LEFT - 8, y + 4);
          }

          ctx.save();
          ctx.translate(14, PADDING_TOP + CHART_H / 2);
          ctx.rotate(-Math.PI / 2);
          ctx.textAlign = 'center';
          ctx.fillStyle = '#333';
          ctx.font = '12px sans-serif';
          ctx.fillText('Docentes', 0, 0);
          ctx.restore();

          data.forEach(function (d, i) {
            const barH = (d.cantidad / maxVal) * CHART_H;
            const x = PADDING_LEFT + i * (BAR_W + GAP);
            const y = PADDING_TOP + CHART_H - barH;

            const num = parseFloat(d.valor);
            ctx.fillStyle = isNaN(num) ? '#adb5bd' : (num < 0 ? '#e55353' : num === 0 ? '#6c757d' : '#4a9eff');
            ctx.fillRect(x, y, BAR_W, barH);

            ctx.fillStyle = '#333';
            ctx.font = '11px sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(d.cantidad, x + BAR_W / 2, y - 4);

            ctx.save();
            ctx.translate(x + BAR_W / 2, PADDING_TOP + CHART_H + 8);
            ctx.rotate(Math.PI / 4);
            ctx.textAlign = 'left';
            ctx.fillStyle = '#444';
            ctx.font = '11px sans-serif';
            ctx.fillText(labels[i], 0, 0);
            ctx.restore();
          });

          ctx.textAlign = 'center';
          ctx.fillStyle = '#333';
          ctx.font = '12px sans-serif';
          ctx.fillText('hrsXCub', canvas.width / 2, canvas.height - 4);
        })();
      </script>
    <% } %>

    <% if (mxgHeatmap && mxgHeatmap.slotLabels && mxgHeatmap.slotLabels.length > 0) { %>
      <h3>Mapa de calor de grupos activos (MXG)</h3>
      <p>Intervalos de 30 minutos desde 07:00 hasta 22:00 hrs.</p>
      <p><strong>Leyenda:</strong> Rojo = menor uso de espacios, Verde = mayor uso de espacios.</p>

      <%# Formulario de filtros %>
      <form method="GET" action="<%= basePath %>/analista/analitica" style="margin-bottom:1rem; display:flex; flex-wrap:wrap; gap:0.75rem; align-items:flex-end;">
        <input type="hidden" name="schoolKey" value="<%= activeSchoolKey || '' %>" />
        <div style="display:flex; flex-direction:column; gap:0.25rem;">
          <label for="filter-semnivel" style="font-size:0.8rem; font-weight:600; color:#555;">Sem/Nivel</label>
          <select id="filter-semnivel" name="semNivel" class="form-control" style="min-width:120px;" <%= hasSemNivelField ? '' : 'disabled' %>>
            <option value=""><%= hasSemNivelField ? '— Todos —' : 'No disponible' %></option>
            <% if (hasSemNivelField) { %>
              <% semNivelOptions.forEach(function(opt) { %>
                <option value="<%= opt %>" <%= filterSemNivel === opt ? 'selected' : '' %>><%= opt %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div style="display:flex; flex-direction:column; gap:0.25rem;">
          <label for="filter-academia" style="font-size:0.8rem; font-weight:600; color:#555;">Academia</label>
          <select id="filter-academia" name="academia" class="form-control" style="min-width:180px;">
            <option value="">— Todas —</option>
            <% academiaOptions.forEach(function(opt) { %>
              <option value="<%= opt %>" <%= filterAcademia === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
        </div>

        <div style="display:flex; flex-direction:column; gap:0.25rem;">
          <label for="filter-asigtipo" style="font-size:0.8rem; font-weight:600; color:#555;">Tipo de asignatura</label>
          <select id="filter-asigtipo" name="asigTipo" class="form-control" style="min-width:150px;" <%= hasAsigTipoField ? '' : 'disabled' %>>
            <option value=""><%= hasAsigTipoField ? '— Todos —' : 'No disponible' %></option>
            <% if (hasAsigTipoField) { %>
              <% asigTipoOptions.forEach(function(opt) { %>
                <option value="<%= opt %>" <%= filterAsigTipo === opt ? 'selected' : '' %>><%= opt %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div style="display:flex; flex-direction:column; gap:0.25rem;">
          <label for="filter-modalidad" style="font-size:0.8rem; font-weight:600; color:#555;">Modalidad</label>
          <select id="filter-modalidad" name="modalidad" class="form-control" style="min-width:120px;">
            <option value="">— Todas —</option>
            <% modalidadOptions.forEach(function(opt) { %>
              <option value="<%= opt %>" <%= filterModalidad === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
        </div>

        <div style="display:flex; flex-direction:column; gap:0.25rem;">
          <label for="filter-carreradesc" style="font-size:0.8rem; font-weight:600; color:#555;">Carrera</label>
          <select id="filter-carreradesc" name="carreraDesc" class="form-control" style="min-width:200px;">
            <option value="">— Todas —</option>
            <% carreraDescOptions.forEach(function(opt) { %>
              <option value="<%= opt %>" <%= filterCarreraDesc === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary">Filtrar</button>
        <% if (filterSemNivel || filterAcademia || filterAsigTipo || filterModalidad || filterCarreraDesc) { %>
          <a href="<%= basePath %>/analista/analitica?schoolKey=<%= encodeURIComponent(activeSchoolKey || '') %>" class="btn btn-secondary">Limpiar filtros</a>
        <% } %>
      </form>

      <% if (!hasSemNivelField || !hasAsigTipoField) { %>
        <p style="font-size:0.85rem; color:#8a6d3b; margin-top:-0.35rem; margin-bottom:0.9rem;">
          Algunos filtros estan deshabilitados porque tu base de datos MXG aun no tiene esas columnas. Reimporta MXG o reinicia la app para actualizar esquema.
        </p>
      <% } %>

      <% if (filterSemNivel || filterAcademia || filterAsigTipo) { %>
        <p style="font-size:0.85rem; color:#6b1735; font-weight:600;">
          Filtros activos:
          <% if (filterSemNivel && hasSemNivelField) { %><span style="margin-right:0.5rem;">Sem/Nivel: <em><%= filterSemNivel %></em></span><% } %>
          <% if (filterAcademia) { %><span style="margin-right:0.5rem;">Academia: <em><%= filterAcademia %></em></span><% } %>
          <% if (filterAsigTipo && hasAsigTipoField) { %><span>Tipo asig.: <em><%= filterAsigTipo %></em></span><% } %>
        </p>
      <% } %>

      <div class="table-wrap">
        <% if (mxgHeatmap.maxCount === 0) { %>
          <p style="color:#888; font-style:italic;">No hay grupos activos con los filtros seleccionados.</p>
        <% } %>
        <table class="heatmap-table">
          <thead>
            <tr>
              <th>Hora</th>
              <% mxgHeatmap.days.forEach((day) => { %>
                <th><%= day.label %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% mxgHeatmap.slotLabels.forEach((slot, slotIndex) => { %>
              <tr>
                <td class="heatmap-hour"><%= slot %></td>
                <% mxgHeatmap.days.forEach((day, dayIndex) => {
                  const count = mxgHeatmap.matrix[slotIndex][dayIndex];
                  const minVisible = Number(mxgHeatmap.minCount || 0);
                  const maxVisible = Number(mxgHeatmap.maxCount || 0);
                  const spread = Math.max(0, maxVisible - minVisible);
                  const intensity = spread > 0 ? ((count - minVisible) / spread) : 0;
                  const hue = Math.round(intensity * 120); // 0=rojo, 120=verde
                  const saturation = 78;
                  const lightness = Math.round(92 - intensity * 52);
                  const bgColor = `hsl(${hue} ${saturation}% ${lightness}%)`;
                  const textColor = intensity >= 0.62 ? '#ffffff' : '#2b1d22';
                %>
                  <td style="background-color: <%= bgColor %>; color: <%= textColor %>; text-align: center; font-weight: 600;"><%= count %></td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p>No hay datos MXG disponibles para construir el mapa de calor.</p>
    <% } %>

    <% if (labDominanceReport) { %>
      <h3>Docentes con predominio de horas en <%= labDominanceReport.targetType %></h3>
      <p>
        Se muestran docentes donde las horas de <strong><%= labDominanceReport.targetType %></strong>
        son mayores que las horas de cualquier otro tipo de asignatura.
      </p>

      <% if (!labDominanceReport.rows || labDominanceReport.rows.length === 0) { %>
        <p>No se encontraron docentes con predominio en <%= labDominanceReport.targetType %>.</p>
      <% } else { %>
        <p><strong>Total docentes:</strong> <%= labDominanceReport.totalDocentes %></p>
        <% const exportLabParams = []; %>
        <% if (activeSchoolKey) exportLabParams.push(`schoolKey=${encodeURIComponent(activeSchoolKey)}`); %>
        <% if (filterSemNivel && hasSemNivelField) exportLabParams.push(`semNivel=${encodeURIComponent(filterSemNivel)}`); %>
        <% if (filterAcademia) exportLabParams.push(`academia=${encodeURIComponent(filterAcademia)}`); %>
        <% if (filterAsigTipo && hasAsigTipoField) exportLabParams.push(`asigTipo=${encodeURIComponent(filterAsigTipo)}`); %>
        <% if (filterModalidad) exportLabParams.push(`modalidad=${encodeURIComponent(filterModalidad)}`); %>
        <% if (filterCarreraDesc) exportLabParams.push(`carreraDesc=${encodeURIComponent(filterCarreraDesc)}`); %>
        <% const exportLabQuery = exportLabParams.length ? `?${exportLabParams.join('&')}` : ''; %>
        <div style="margin-bottom:10px;">
          <a href="<%= basePath %>/analista/analitica/export-laboratorio-csv<%= exportLabQuery %>" class="btn btn-secondary">Descargar reporte CSV</a>
        </div>
        <div class="table-wrap" style="margin-bottom:1rem;">
          <table>
            <thead>
              <tr>
                <th>Docente</th>
                <th>Num. Emp</th>
                <th>RFC</th>
                <th>Horas L-LABORATORIO</th>
                <th>Otro tipo con mas horas</th>
                <th>Horas de ese otro tipo</th>
                <th>Total horas</th>
                <th>% L-LABORATORIO</th>
              </tr>
            </thead>
            <tbody>
              <% labDominanceReport.rows.forEach(function(item) { %>
                <tr>
                  <td><%= item.nombre || '-' %></td>
                  <td><%= item.numEmp || '-' %></td>
                  <td><%= item.rfc || '-' %></td>
                  <td><%= Number(item.laboratorioHours || 0).toFixed(2) %></td>
                  <td><%= item.topOtherType || '-' %></td>
                  <td><%= Number(item.topOtherHours || 0).toFixed(2) %></td>
                  <td><%= Number(item.totalHours || 0).toFixed(2) %></td>
                  <td><%= Number(item.laboratorioShare || 0).toFixed(2) %>%</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>

    <% if (theoryLabCoverageReport) { %>
      <h3>Validacion T-TEORIA vs L-LABORATORIO por grupo-materia</h3>
      <p>
        Se reportan: 1) docentes que imparten <strong>T-TEORIA</strong> pero no estan en
        <strong>L-LABORATORIO</strong> del mismo grupo-materia, y 2) grupos-materia con
        <strong>L-LABORATORIO</strong> sin ningun docente en <strong>T-TEORIA</strong>.
      </p>
      <p>
        <strong>Pares evaluados:</strong> <%= theoryLabCoverageReport.totalParesEvaluados %>
        | <strong>Docentes T sin L:</strong> <%= theoryLabCoverageReport.totalDocentesTeoriaSinLaboratorio %>
        | <strong>Grupos con L sin T:</strong> <%= theoryLabCoverageReport.totalGruposLaboratorioSinTeoria %>
      </p>

      <div style="margin-bottom:10px;">
        <a href="<%= basePath %>/analista/analitica/export-teoria-laboratorio-csv?schoolKey=<%= encodeURIComponent(activeSchoolKey || '') %>" class="btn btn-secondary">Descargar reporte CSV</a>
      </div>

      <h4>Docentes de T-TEORIA que no aparecen en L-LABORATORIO</h4>
      <% if (!theoryLabCoverageReport.theoryTeacherMissingLabRows || theoryLabCoverageReport.theoryTeacherMissingLabRows.length === 0) { %>
        <p style="color:#2d6a2d;">No se detectaron docentes de T-TEORIA faltantes en L-LABORATORIO.</p>
      <% } else { %>
        <div class="table-wrap" style="margin-bottom:1rem;">
          <table>
            <thead>
              <tr>
                <th>Docente</th>
                <th>Num. Emp</th>
                <th>RFC</th>
                <th>Grupo</th>
                <th>Turno</th>
                <th>Carrera</th>
                <th>Materia base</th>
                <th>Asignatura(s) T</th>
                <th>Asignatura(s) L</th>
                <th>Docente(s) en L</th>
              </tr>
            </thead>
            <tbody>
              <% theoryLabCoverageReport.theoryTeacherMissingLabRows.forEach(function(item) { %>
                <tr>
                  <td><%= item.docente || '-' %></td>
                  <td><%= item.numEmp || '-' %></td>
                  <td><%= item.rfc || '-' %></td>
                  <td><%= item.grupo || '-' %></td>
                  <td><%= item.turno || '-' %></td>
                  <td><%= item.carrera || '-' %></td>
                  <td><%= item.asignaturaBase || '-' %></td>
                  <td><%= item.asignaturasTeoria || '-' %></td>
                  <td><%= item.asignaturasLaboratorio || '-' %></td>
                  <td><%= item.docentesLaboratorio || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <h4>Grupos-materia con L-LABORATORIO y sin T-TEORIA</h4>
      <% if (!theoryLabCoverageReport.labWithoutTheoryRows || theoryLabCoverageReport.labWithoutTheoryRows.length === 0) { %>
        <p style="color:#2d6a2d;">No se detectaron grupos con L-LABORATORIO sin T-TEORIA.</p>
      <% } else { %>
        <div class="table-wrap" style="margin-bottom:1rem;">
          <table>
            <thead>
              <tr>
                <th>Grupo</th>
                <th>Turno</th>
                <th>Carrera</th>
                <th>Materia base</th>
                <th>Asignatura(s) L</th>
                <th>Docente(s) en L</th>
                <th>Total docentes en L</th>
              </tr>
            </thead>
            <tbody>
              <% theoryLabCoverageReport.labWithoutTheoryRows.forEach(function(item) { %>
                <tr>
                  <td><%= item.grupo || '-' %></td>
                  <td><%= item.turno || '-' %></td>
                  <td><%= item.carrera || '-' %></td>
                  <td><%= item.asignaturaBase || '-' %></td>
                  <td><%= item.asignaturasLaboratorio || '-' %></td>
                  <td><%= item.docentesLaboratorio || '-' %></td>
                  <td><%= item.totalDocentesLaboratorio || 0 %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>

    <h3>Docentes en MxG con traslapes en RUAA</h3>
    <% if (!mxgRuaaOverlapReport) { %>
      <p>No hay datos disponibles. Carga MXG y RUAA para la escuela activa.</p>
    <% } else if (mxgRuaaOverlapReport.totalTeachersWithConflicts === 0) { %>
      <p style="color:#2d6a2d;">No se encontraron traslapes de horario entre los docentes de MXG y el archivo RUAA.</p>
    <% } else { %>
      <p>
        <strong><%= mxgRuaaOverlapReport.totalTeachersWithConflicts %></strong>
        docente(s) en MXG tienen traslapes de horario con clases registradas en RUAA.
      </p>
      <div style="margin-bottom:10px;">
        <a href="<%= basePath %>/analista/analitica/export-mxg-ruaa-overlap-csv?schoolKey=<%= encodeURIComponent(activeSchoolKey || '') %>" class="btn btn-secondary">Descargar reporte CSV</a>
      </div>
      <div class="table-wrap" style="margin-bottom:1rem;">
        <table>
          <thead>
            <tr>
              <th>Docente</th>
              <th>Num. Emp</th>
              <th>RFC</th>
              <th>Asignatura MXG</th>
              <th>Grupo</th>
              <th>Dia</th>
              <th>Horario MXG</th>
              <th>Horario RUAA</th>
            </tr>
          </thead>
          <tbody>
            <% mxgRuaaOverlapReport.rows.forEach(function(teacher) { %>
              <% teacher.conflicts.forEach(function(conflict, idx) { %>
                <tr>
                  <% if (idx === 0) { %>
                    <td rowspan="<%= teacher.conflicts.length %>"><%= teacher.nombre || '-' %></td>
                    <td rowspan="<%= teacher.conflicts.length %>"><%= teacher.numEmp || '-' %></td>
                    <td rowspan="<%= teacher.conflicts.length %>"><%= teacher.rfc || '-' %></td>
                  <% } %>
                  <td><%= conflict.asignaturaDesc || '-' %></td>
                  <td><%= conflict.grupo || '-' %></td>
                  <td><%= conflict.day %></td>
                  <td><%= conflict.mxgRange || '-' %></td>
                  <td><%= conflict.ruaaRange || '-' %></td>
                </tr>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<%- include('partials/foot') %>
